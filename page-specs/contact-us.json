{
  "slug": "contact-us",
  "title": "Contact Us | Pet Emergency Center Fort Lauderdale",
  "description": "Contact Pet Emergency Center in Fort Lauderdale. Call (954) 772-0420. Open weeknights, weekends, and holidays. 921 East Cypress Creek Road, Fort Lauderdale, FL.",
  "ogTitle": "Contact Pet Emergency Center | Fort Lauderdale Emergency Vet",
  "ogDescription": "Call (954) 772-0420 or walk in. Independently owned emergency veterinary care in Fort Lauderdale. Open evenings, weekends, and holidays.",
  "extraStyles": ["styles/services.css"],
  "main": "<main id=\"main\">\n\n  <section id=\"top\" class=\"pec-svc-hero\">\n    <div class=\"pec-svc-hero__inner\">\n      <div class=\"pec-svc-hero__grid\">\n        <div>\n          <div class=\"pec-hero__eyebrow\"><span class=\"pec-dot\"></span> Open now · Walk-ins welcome</div>\n          <h1 class=\"pec-h1\">Contact <span class=\"pec-h1__accent\">Pet Emergency Center</span>.</h1>\n          <p class=\"pec-svc-hero__sub\">Whether you need help right now, are planning ahead, or just have a question, here is how to reach us. We are open evenings, weekends, and holidays.</p>\n          <div class=\"pec-svc-hero__cta\">\n            <a href=\"tel:9547720420\" class=\"pec-btn pec-btn--primary pec-btn--lg\"><svg width=\"20\" height=\"20\" aria-hidden=\"true\"><use href=\"#i-phone\"/></svg> Call (954) 772-0420</a>\n            <a href=\"https://www.google.com/maps/?q=921+E+Cypress+Creek+Rd+Fort+Lauderdale+FL+33334\" rel=\"noopener noreferrer\" target=\"_blank\" class=\"pec-btn pec-btn--outline pec-btn--lg\"><svg width=\"20\" height=\"20\" aria-hidden=\"true\"><use href=\"#i-pin\"/></svg> Get Directions</a>\n          </div>\n          <div class=\"pec-svc-trust\">\n            <span class=\"pec-svc-trust__item\"><svg width=\"18\" height=\"18\" aria-hidden=\"true\"><use href=\"#i-check\"/></svg> No appointment needed for emergencies</span>\n            <span class=\"pec-svc-trust__item\"><svg width=\"18\" height=\"18\" aria-hidden=\"true\"><use href=\"#i-clock\"/></svg> Weeknights 5 PM – 8 AM</span>\n            <span class=\"pec-svc-trust__item\"><svg width=\"18\" height=\"18\" aria-hidden=\"true\"><use href=\"#i-clock\"/></svg> Weekends &amp; holidays 24/7</span>\n          </div>\n        </div>\n        <div class=\"pec-svc-hero__media\">\n          <div class=\"pec-svc-hero__art\"><span class=\"pec-svc-hero__chip\">Fort Lauderdale</span><img src=\"../img/story-hero.jpg\" alt=\"Pet Emergency Center exterior in Fort Lauderdale\"></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"pec-narr\">\n    <div class=\"pec-wrap\">\n      <div class=\"pec-eyebrow\">How to reach us</div>\n      <h2 class=\"pec-h2\">Phone, Address, Hours.</h2>\n      <div class=\"pec-contact-info\">\n        <div class=\"pec-contact-info__item\">\n          <span class=\"pec-contact-info__icon\"><svg width=\"22\" height=\"22\" aria-hidden=\"true\"><use href=\"#i-phone\"/></svg></span>\n          <div class=\"pec-contact-info__h\">Phone</div>\n          <div class=\"pec-contact-info__big\"><a href=\"tel:9547720420\">(954) 772-0420</a></div>\n          <p class=\"pec-contact-info__sub\">Call any time we are open. For emergencies, call directly. For general questions, leave a message and we will return your call.</p>\n        </div>\n        <div class=\"pec-contact-info__item\">\n          <span class=\"pec-contact-info__icon\"><svg width=\"22\" height=\"22\" aria-hidden=\"true\"><use href=\"#i-pin\"/></svg></span>\n          <div class=\"pec-contact-info__h\">Address</div>\n          <div class=\"pec-contact-info__big\">921 East Cypress Creek Rd.<br>Fort Lauderdale, FL 33334</div>\n          <p class=\"pec-contact-info__sub\">Walk-ins welcome during operating hours. No appointment needed for emergency visits.</p>\n        </div>\n        <div class=\"pec-contact-info__item\">\n          <span class=\"pec-contact-info__icon\"><svg width=\"22\" height=\"22\" aria-hidden=\"true\"><use href=\"#i-clock\"/></svg></span>\n          <div class=\"pec-contact-info__h\">Hours of Operation</div>\n          <div class=\"pec-contact-info__big\" style=\"font-size:18px;line-height:1.4\"><strong>Weeknights:</strong> 5:00 PM to 8:00 AM<br><strong>Weekends &amp; Holidays:</strong> Open 24 hours</div>\n          <p class=\"pec-contact-info__sub\">For non-urgent questions or triage, book a $75 telehealth consultation available statewide across Florida. <a href=\"/telemedicine/\" class=\"pec-link\">Learn more</a></p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"pec-narr pec-narr--tint\">\n    <div class=\"pec-wrap\">\n      <div class=\"pec-eyebrow\">Find us</div>\n      <h2 class=\"pec-h2\">Driving Directions and Location.</h2>\n      <p>Pet Emergency Center is located on East Cypress Creek Road in Fort Lauderdale, easy to reach from I-95, the Florida Turnpike, and most major routes throughout Broward County.</p>\n      <div class=\"pec-map-embed\">\n        <iframe src=\"https://www.google.com/maps?q=921+E+Cypress+Creek+Rd+Fort+Lauderdale+FL+33334&output=embed\" loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\" title=\"Map showing Pet Emergency Center at 921 E Cypress Creek Rd, Fort Lauderdale, FL\"></iframe>\n      </div>\n      <div class=\"pec-cards__grid pec-cards__grid--3\" style=\"margin-top:40px\">\n        <article class=\"pec-card\"><h3>From the North</h3><p>Pompano Beach, Deerfield Beach, Boca Raton: Take I-95 South to Cypress Creek Road (Exit 33). Head east on Cypress Creek Road. Pet Emergency Center is on the right.</p></article>\n        <article class=\"pec-card\"><h3>From the South</h3><p>Hollywood, Davie, Pembroke Pines: Take I-95 North to Cypress Creek Road (Exit 33). Head east on Cypress Creek Road. Pet Emergency Center is on the right.</p></article>\n        <article class=\"pec-card\"><h3>From the West</h3><p>Coral Springs, Plantation, Sunrise, Weston: Take Sawgrass Expressway or Florida Turnpike to I-595 East, then I-95 North to Cypress Creek Road (Exit 33). Head east on Cypress Creek Road.</p></article>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"pec-narr\">\n    <div class=\"pec-wrap\">\n      <div class=\"pec-eyebrow\">Send us a message</div>\n      <h2 class=\"pec-h2\">General Questions and Non-Urgent Inquiries.</h2>\n      <p>For non-emergency inquiries, fill out the form below and we will get back to you. For emergencies, please call us directly. Forms are checked during operating hours, so a phone call is always faster.</p>\n      <div class=\"pec-callout\"><strong>If your pet is in distress, do not use the form.</strong> Call us. <a href=\"tel:9547720420\" style=\"color:var(--pec-accent)\">(954) 772-0420</a>.</div>\n      <form class=\"pec-form\" action=\"mailto:info@petemergencycenters.com\" method=\"POST\" enctype=\"text/plain\" style=\"margin-top:32px;max-width:none\">\n        <div class=\"pec-form__row pec-form__row--two\">\n          <div class=\"pec-form__row\"><label for=\"f-name\">Name</label><input id=\"f-name\" name=\"name\" type=\"text\" required></div>\n          <div class=\"pec-form__row\"><label for=\"f-email\">Email</label><input id=\"f-email\" name=\"email\" type=\"email\" required></div>\n        </div>\n        <div class=\"pec-form__row pec-form__row--two\">\n          <div class=\"pec-form__row\"><label for=\"f-phone\">Phone <span style=\"text-transform:none;font-weight:500;color:var(--pec-muted);letter-spacing:0\">(optional)</span></label><input id=\"f-phone\" name=\"phone\" type=\"tel\"></div>\n          <div class=\"pec-form__row\"><label for=\"f-pet\">Pet's name <span style=\"text-transform:none;font-weight:500;color:var(--pec-muted);letter-spacing:0\">(optional)</span></label><input id=\"f-pet\" name=\"pet\" type=\"text\"></div>\n        </div>\n        <div class=\"pec-form__row\">\n          <label for=\"f-subject\">Subject</label>\n          <select id=\"f-subject\" name=\"subject\" required>\n            <option value=\"\">Select a topic</option>\n            <option>General question</option>\n            <option>Records request</option>\n            <option>Billing question</option>\n            <option>Career inquiry</option>\n            <option>Referring veterinarian</option>\n            <option>Other</option>\n          </select>\n        </div>\n        <div class=\"pec-form__row\">\n          <label for=\"f-message\">Message</label>\n          <textarea id=\"f-message\" name=\"message\" required></textarea>\n          <span class=\"pec-form__hint\">For emergencies, please call (954) 772-0420 instead of using this form.</span>\n        </div>\n        <button type=\"submit\" class=\"pec-btn pec-btn--primary pec-btn--lg pec-form__submit\">Send Message</button>\n      </form>\n    </div>\n  </section>\n\n  <section class=\"pec-cards pec-cards--tint\">\n    <div class=\"pec-wrap\">\n      <div class=\"pec-section-head\"><div class=\"pec-eyebrow\">Specialized contact</div><h2 class=\"pec-h2\">For Specific Needs.</h2></div>\n      <div class=\"pec-cards__grid pec-cards__grid--3\">\n        <article class=\"pec-card\"><h3>For Pet Owners</h3><p>Call <a href=\"tel:9547720420\" class=\"pec-link\">(954) 772-0420</a> for any pet care question. Walk in any time we are open.</p></article>\n        <article class=\"pec-card\"><h3>For Referring Veterinarians</h3><p>Call <a href=\"tel:9547720420\" class=\"pec-link\">(954) 772-0420</a> to coordinate a referral or discuss a case. <a href=\"/referring-hospitals/\" class=\"pec-link\">How we work with referring practices</a></p></article>\n        <article class=\"pec-card\"><h3>For Career Inquiries</h3><p>Email <a href=\"mailto:careers@petemergencycenters.com\" class=\"pec-link\">careers@petemergencycenters.com</a> or call (954) 772-0420 and ask for Paige. <a href=\"/career-opportunities/\" class=\"pec-link\">See open positions</a></p></article>\n        <article class=\"pec-card\"><h3>For Rescue Organizations</h3><p>Email <a href=\"mailto:rescues@petemergencycenters.com\" class=\"pec-link\">rescues@petemergencycenters.com</a> to discuss working together. <a href=\"/pet-rescue-groups/\" class=\"pec-link\">Rescue group directory</a></p></article>\n        <article class=\"pec-card\"><h3>For Records Requests</h3><p>Call us during operating hours or use the contact form above. Records are typically processed within 24 hours.</p></article>\n        <article class=\"pec-card\"><h3>For Media Inquiries</h3><p>Email <a href=\"mailto:media@petemergencycenters.com\" class=\"pec-link\">media@petemergencycenters.com</a> or call (954) 772-0420 and ask for Paige.</p></article>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"pec-final\">\n    <div class=\"pec-wrap pec-final__grid\">\n      <div class=\"pec-final__copy\">\n        <div class=\"pec-eyebrow pec-eyebrow--light\">Compassionate care. Always here.</div>\n        <h2 class=\"pec-h2 pec-h2--light pec-final__h\">When Your Pet Needs Help, Call Us. When You Have Time to Plan, Reach Out Anytime.</h2>\n        <p class=\"pec-final__p\">We are part of this community, and we are glad you found us.</p>\n        <div class=\"pec-final__cta\">\n          <a href=\"tel:9547720420\" class=\"pec-btn pec-btn--white pec-btn--lg\"><svg width=\"20\" height=\"20\" aria-hidden=\"true\"><use href=\"#i-phone\"/></svg> Call (954) 772-0420</a>\n          <a href=\"/telemedicine/\" class=\"pec-btn pec-btn--outline pec-btn--outline-white pec-btn--lg\"><svg width=\"20\" height=\"20\" aria-hidden=\"true\"><use href=\"#i-video\"/></svg> Book a Telehealth Consultation</a>\n        </div>\n      </div>\n      <div class=\"pec-final__contact\">\n        <div class=\"pec-contact-card\">\n          <h3 class=\"pec-h3 pec-h3--light\">Pet Emergency Center</h3>\n          <div class=\"pec-contact-card__row\"><svg width=\"18\" height=\"18\" aria-hidden=\"true\"><use href=\"#i-pin\"/></svg><div>921 East Cypress Creek Rd.<br>Fort Lauderdale, FL 33334</div></div>\n          <div class=\"pec-contact-card__row\"><svg width=\"18\" height=\"18\" aria-hidden=\"true\"><use href=\"#i-phone\"/></svg><div><a href=\"tel:9547720420\">(954) 772-0420</a></div></div>\n          <div class=\"pec-contact-card__row\"><svg width=\"18\" height=\"18\" aria-hidden=\"true\"><use href=\"#i-clock\"/></svg><div><strong>Weeknights</strong> 5:00 PM to 8:00 AM<br><strong>Weekends &amp; Holidays</strong> Open 24/7</div></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n</main>"
}
